{
  "name": "jerseys-store",
  "version": "1.0.0",
  "description": "Tienda online de camisetas de fútbol - Jersey Store",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "npm run assets:version && npm --prefix server start",
    "install:server": "npm --prefix server install",
    "reset-db": "npm --prefix server run reset-db",
    "clean-demo": "node scripts/clean-demo-db.js",
    "assets:version": "node scripts/apply-asset-version.js",
    "assets:version:dry": "node scripts/apply-asset-version.js --dry-run"
  },
  "keywords": [
    "ecommerce",
    "jerseys",
    "futbol",
    "tienda-online"
  ],
