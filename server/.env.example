# Copiá a .env y completá los valores. Nunca subas .env al repo.



# Obligatorias

JWT_SECRET=cambiar_por_un_secreto_de_al_menos_32_caracteres

MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/jerseys_store_db

APP_BASE_URL=http://localhost:3000

# Orígenes extra permitidos (CORS), separados por coma. Ej: https://www.tudominio.com

# ALLOWED_ORIGINS=



# Bootstrap admin (solo crea si no hay admin). Nunca subas contraseñas reales al repo.

# ADMIN_INICIAL_EMAIL=admin@tudominio.com

# ADMIN_INICIAL_PASS=CambiarYa123

# Solo para resetear el admin existente una vez; SACALO después.

# ADMIN_FORCE_RESET=false



# Tienda

NOMBRE_TIENDA=Jersey Store

WHATSAPP_NUMERO=54911XXXXXXXX



# Mercado Pago

MP_ACCESS_TOKEN=

MP_WEBHOOK_SECRET=

MP_SANDBOX=true



# Cloudinary

CLOUDINARY_CLOUD_NAME=

# Preferido: subida firmada (admin). Si faltan key/secret, se usa el preset unsigned.

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

CLOUDINARY_UPLOAD_PRESET=



# Email (SMTP / Brevo)

SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASS=

SMTP_FROM=



# Cron (Bearer token para endpoints de limpieza)

CRON_SECRET=



# Opcional local

# USE_NGROK=true

# NGROK_AUTHTOKEN=

# WEBHOOK_BASE_URL=


