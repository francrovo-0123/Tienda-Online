# Copiá a .env y completá los valores. Nunca subas .env al repo.



# Obligatorias

JWT_SECRET=cambiar_por_un_secreto_de_al_menos_32_caracteres

MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/jerseys_store_db

APP_BASE_URL=http://localhost:3000

# Cache-busting de CSS/JS en HTML (?v=…). Si está vacío, usa data/asset-version.json.
# Tras cambiarla: npm run assets:version
# ASSET_VERSION=15.2

# Orígenes extra permitidos (CORS), separados por coma. Ej: https://www.tudominio.com

# ALLOWED_ORIGINS=



# Bootstrap admin (solo crea si no hay admin). Nunca subas contraseñas reales al repo.

# ADMIN_INICIAL_EMAIL=admin@tudominio.com

# ADMIN_INICIAL_PASS=CambiarYa123

# Solo para resetear el admin existente una vez; SACALO después.

# ADMIN_FORCE_RESET=false



# Tienda (datos estructurales — sin panel de configuración en el admin)
# STORE_NAME=Jersey Store
# WHATSAPP_NUMBER=5491123456789
# AFIP_URL=https://servicios1.afip.gov.ar/f960/DATA/...
STORE_NAME=Jersey Store
WHATSAPP_NUMBER=54911XXXXXXXX
AFIP_URL=

# Legacy (opcionales; se usan solo si faltan las variables de arriba)
# NOMBRE_TIENDA=Jersey Store
# WHATSAPP_NUMERO=54911XXXXXXXX



# Mercado Pago

MP_ACCESS_TOKEN=

MP_WEBHOOK_SECRET=

MP_SANDBOX=true



# Rate-limit: IPs de reverse proxies de confianza (coma-separadas).
# Solo si el proxy REEMPLAZA X-Forwarded-For (no append del cliente).
# En Vercel no hace falta: se usa el XFF del edge automáticamente.
# TRUSTED_PROXIES=127.0.0.1,10.0.0.1



# Cloudinary (subida firmada del admin — las 3 primeras son obligatorias)

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

# Opcional / legacy (el flujo actual del admin NO usa preset unsigned)

# CLOUDINARY_UPLOAD_PRESET=



# Email (SMTP / Brevo)

SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASS=

SMTP_FROM=



# Cron (Bearer token para endpoints de limpieza)

CRON_SECRET=



# Opcional local

# USE_NGROK=true

# NGROK_AUTHTOKEN=

# WEBHOOK_BASE_URL=


