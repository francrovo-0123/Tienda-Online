# Cadena de conexión a MongoDB Atlas o instancia local
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/jerseys_store_db?retryWrites=true&w=majority

# Puerto del servidor (opcional, por defecto 3000)
# PORT=3000

# Secreto para firmar tokens JWT (mínimo 32 caracteres; obligatorio en producción)
JWT_SECRET=tu_secreto_jwt_seguro_de_al_menos_32_caracteres

# Secreto para autorizar el cron externo (cron-job.org) en GET /api/cron/limpiar-stock
# Configurá en cron-job.org: URL https://tu-dominio.vercel.app/api/cron/limpiar-stock
# Header Authorization: Bearer <CRON_SECRET>, cada 5 minutos
CRON_SECRET=

# Credenciales del administrador inicial (solo se usa si no existe ningún admin)
ADMIN_INICIAL_EMAIL=admin@tudominio.com
ADMIN_INICIAL_PASS=tu_contraseña_segura_aqui

# Configuración SMTP (Mailtrap u otro proveedor)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=tu_usuario_mailtrap
SMTP_PASS=tu_password_mailtrap
SMTP_FROM="Jerseys Store <noreply@jerseysstore.com>"

# Configuración pública de la tienda (marca blanca)
NOMBRE_TIENDA=Jerseys Store
WHATSAPP_NUMERO=5491123456789
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# Mercado Pago (Checkout Pro) — token de Producción o Sandbox desde el panel de desarrolladores
MP_ACCESS_TOKEN=TEST-tu_access_token_de_mercadopago
MP_SANDBOX=true

# ngrok — túnel público para webhooks y back_urls de Mercado Pago en desarrollo
USE_NGROK=true
NGROK_AUTHTOKEN=tu_authtoken_de_ngrok

# URL pública de la tienda (se actualiza automáticamente si USE_NGROK=true)
APP_BASE_URL=http://localhost:3000
